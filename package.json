{
  "name": "helm-pilot",
  "description": "A high-performance, enterprise-grade Kubernetes release dashboard and Helm chart management system.",
  "private": true,
  "version": "0.3.0",
  "license": "GPL-3.0-only",
  "type": "module",
  "scripts": {
    "start:dev": "next dev --port 3000",
    "start:prod": "next start --port 3000",
    "build:prod": "next build",
    "type:check": "tsc --noEmit",
    "test:unit": "vitest run --silent",
    "test:cov": "vitest run --coverage --silent",
    "test:watch": "vitest",
    "fmt:lint": "eslint . --fix",
    "fmt:format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "docker:release": "sh scripts/docker.sh",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "deps:update": "npm-check-updates -u && npm run deps:install",
    "deps:install": "npm install --no-fund --no-audit --verbose",
    "gen:changelog": "node scripts/changelog.mjs --bump"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "jose": "^6.2.3",
    "js-yaml": "^5.2.1",
    "lucide-react": "^1.24.0",
    "motion": "^12.42.2",
    "next": "^16.2.10",
    "openid-client": "^6.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.1",
    "@types/react": "19.2.17",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.10.0",
    "jsdom": "^29.1.1",
    "npm-check-updates": "^22.2.9",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.2",
    "typescript": "~7.0.2",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "next": {
      "postcss": ">=8.5.10"
    }
  }
}
