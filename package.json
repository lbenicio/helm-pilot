{
  "name": "helm-pilot",
  "description": "A high-performance, enterprise-grade Kubernetes release dashboard and Helm chart management system.",
  "private": true,
  "version": "0.2.5",
  "license": "GPL-3.0-only",
  "type": "module",
  "scripts": {
    "start:dev": "next dev --port 3000",
    "start:prod": "next start --port 3000",
    "build:prod": "next build",
    "type:check": "tsc --noEmit",
    "fmt:lint": "eslint . --fix",
    "fmt:format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "docker:build": "docker image build --tag helm-pilot:latest .",
    "docker:push": "docker image push helm-pilot:latest",
    "docker:release": "npm run docker:build && npm run docker:push",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "deps:update": "npm-check-updates -u && npm run deps:install",
    "deps:install": "npm install --no-fund --no-audit --verbose",
    "gen:changelog": "node scripts/changelog.mjs --bump"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "jose": "^6.2.3",
    "js-yaml": "^5.1.0",
    "lucide-react": "^1.21.0",
    "motion": "^12.42.0",
    "next": "^16.2.9",
    "openid-client": "^6.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.0.1",
    "@types/react": "19.2.17",
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.9.1",
    "npm-check-updates": "^22.2.7",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.0"
  },
  "overrides": {
      "next": {
          "postcss": ">=8.5.10"
      }
  }
}
